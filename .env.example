POLYGON_API_KEY=

# Schwab Developer API (OAuth 2.0)
# App Key and Secret from developer.schwab.com → My Apps
# Refresh token obtained via one-time browser OAuth flow (7-day TTL, auto-rotates on use)
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REFRESH_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT="script:fetch-wsb:v1.0 (by u/yourusername)"
MONGO_URI=
SMF_SMTP_HOST=smtp.gmail.com
SMF_SMTP_PORT=587
SMF_SMTP_USER=
SMF_SMTP_PASS=
SMF_EMAIL_FROM=
SMF_EMAIL_TO=
SMF_EMAIL_SUBJECT=SMF Daily Report
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
APEWISDOM_BASE_URL=https://apewisdom.io/api/v1.0
APEWISDOM_FILTER=all
APEWISDOM_TIMEOUT=20
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
GDELT_TIMEOUT=20
GDELT_LOOKBACK_HOURS=24
GDELT_LIMIT=100
GDELT_BREAKING_WINDOW_MINUTES=60